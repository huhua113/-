rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: scripts
    // Document ID: auto-generated
    // Fields:
    //   - topic: string (required)
    //   - script: string (required)
    //   - storyboards: list (required)
    //   - sources: list (optional)
    //   - uid: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "huhuats@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidScript(data) {
      return data.keys().hasAll(['topic', 'script', 'storyboards', 'uid', 'createdAt']) &&
             data.topic is string && data.topic.size() > 0 && data.topic.size() < 200 &&
             data.script is string && data.script.size() > 0 && data.script.size() < 10000 &&
             data.storyboards is list && data.storyboards.size() <= 20 &&
             data.uid == request.auth.uid &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /scripts/{scriptId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidScript(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidScript(request.resource.data) &&
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isAdmin();
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
